# LAN address of orexis, reachable from philia (e.g. a .home hostname or static LAN IP)
OREXIS_LAN_HOST=orexis.home

# Must match the orexis .env's database/secrets values
SPRING_DATA_NEO4J_AUTHENTICATION_PASSWORD=CHANGE_ME
SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_DISCORD_CLIENT_ID=CHANGE_ME
SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_DISCORD_CLIENT_SECRET=CHANGE_ME
APPLICATION_SECURITY_USER_KEY_SECRET=CHANGE_ME
APPLICATION_SECURITY_GATEWAY_SIGNING_SECRET=CHANGE_ME
APPLICATION_FRONTEND_URL_HSR=https://remuria.net
