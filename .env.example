# LAN-resolvable addresses for orexis and philia. Required for the Mongo
# replica set's member list (docker-compose.db.yml's mongo-rs-init) - members
# on different physical hosts can't resolve each other's Docker Compose
# service names, only real network addresses.
OREXIS_LAN_HOST=orexis.home
PHILIA_LAN_HOST=philia.home

# Database hosts - containers defined in docker-compose.db.yml, running
# alongside this stack on orexis. Philia (docker-compose.db.philia.yml) is a
# secondary/cold-standby, not the primary - see README.md "Database Topology".
SPRING_DATA_MONGODB_HOST=mongo-orexis
SPRING_DATA_MONGODB_PORT=27017
SPRING_DATA_MONGODB_DATABASE=hsrdbmongo
SPRING_DATA_NEO4J_URI=bolt://neo4j-orexis:7687
SPRING_DATA_NEO4J_AUTHENTICATION_USERNAME=neo4j
SPRING_DATA_NEO4J_AUTHENTICATION_PASSWORD=CHANGE_ME
SPRING_DATA_REDIS_HOST=redis-orexis

# Discord OAuth
SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_DISCORD_CLIENT_ID=CHANGE_ME
SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_DISCORD_CLIENT_SECRET=CHANGE_ME

# HMAC signing secrets (must match between Aquila and Celestia)
APPLICATION_SECURITY_USER_KEY_SECRET=CHANGE_ME
APPLICATION_SECURITY_GATEWAY_SIGNING_SECRET=CHANGE_ME

# Frontend URLs (set to your public domain, or http://localhost for local testing)
APPLICATION_FRONTEND_URL_HSR=https://remuria.net
APPLICATION_LOGIN_SUCCESS_URL_HSR=https://remuria.net
APPLICATION_LOGIN_FAILURE_URL_HSR=https://remuria.net

# Cloudflare Tunnel
CLOUDFLARE_TUNNEL_TOKEN=CHANGE_ME
